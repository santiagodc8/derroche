---
import Layout from '../layouts/Layout.astro';

const whatsapp =
  'https://wa.me/573147241900?text=' +
  encodeURIComponent('Hola Derroche, quiero información para reservar.');
---

<Layout title="Página no encontrada · Derroche">
  <main id="top" class="relative min-h-[100svh] w-full overflow-hidden bg-ink-950 flex items-center">
    <!-- Atmospheric backdrop -->
    <div class="absolute inset-0">
      <div class="absolute inset-0 bg-gradient-to-br from-ink-950 via-bordeaux-deep to-ink-900"></div>
      <div
        class="absolute -right-40 top-1/4 h-[640px] w-[640px] rounded-full opacity-30 blur-3xl"
        style="background: radial-gradient(closest-side, #C8102E, transparent);"
      >
      </div>
      <div
        class="absolute inset-0 opacity-[0.07]"
        style="background-image: radial-gradient(circle at 1px 1px, #F5E9D7 1px, transparent 0); background-size: 38px 38px;"
      >
      </div>
    </div>

    <div class="relative z-10 mx-auto max-w-[1500px] px-6 lg:px-12 w-full">
      <p class="eyebrow flex items-center gap-4">
        <span class="h-px w-10 bg-crimson"></span>
        Error 404
      </p>

      <p class="font-numeric text-cream text-[clamp(6rem,22vw,18rem)] leading-none italic mt-4">404</p>

      <h1 class="font-display text-cream leading-[0.95] text-[clamp(2rem,5vw,4rem)] mt-2">
        Esta página se<br />
        <span class="italic font-accent text-crimson">tomó la noche libre.</span>
      </h1>

      <p class="font-accent italic text-cream/70 text-xl mt-8 max-w-lg leading-relaxed">
        No encontramos lo que buscabas, pero tu próxima escapada sigue
        esperándote. Volvamos al inicio.
      </p>

      <div class="mt-12 flex flex-col sm:flex-row gap-4">
        <a href="/" class="btn-primary">
          <span>Volver al inicio</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href={whatsapp} target="_blank" rel="noopener" class="btn-ghost">
          <span>Escríbenos por WhatsApp</span>
        </a>
      </div>
    </div>
  </main>
</Layout>
