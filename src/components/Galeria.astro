---
const fotos = [
  {
    src: '/habitaciones/presidencial/presidencial2.jpeg',
    alt: 'Suite Presidencial con jacuzzi privado',
    span: 'col-span-12 lg:col-span-7 lg:row-span-2 aspect-[4/3] lg:aspect-auto',
  },
  {
    src: '/habitaciones/junior/junior2.jpeg',
    alt: 'Habitación Junior',
    span: 'col-span-6 lg:col-span-5 aspect-square',
  },
  {
    src: '/habitaciones/solarium/solarium2.jpeg',
    alt: 'Suite Solarium Plus con solárium privado',
    span: 'col-span-6 lg:col-span-5 aspect-square',
  },
  {
    src: '/habitaciones/silver/silver2.jpeg',
    alt: 'Habitación Silver',
    span: 'col-span-12 lg:col-span-4 aspect-[4/3]',
  },
  {
    src: '/habitaciones/presidencial/presidencial3.jpeg',
    alt: 'Detalle interior de la Suite Presidencial',
    span: 'col-span-12 lg:col-span-8 aspect-[16/9]',
  },
];
---

<section id="galeria" class="relative py-28 lg:py-36 bg-ink-950 overflow-hidden">
  <div class="mx-auto max-w-[1500px] px-6 lg:px-12">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 mb-16" data-reveal>
      <div>
        <p class="eyebrow flex items-center gap-4">
          <span class="h-px w-10 bg-crimson"></span>
          Galería
        </p>
        <h2 class="section-heading mt-6">
          La atmósfera<br />
          <span class="italic font-accent text-crimson">de Derroche.</span>
        </h2>
      </div>
      <p class="font-accent italic text-cream/70 text-lg max-w-md leading-relaxed">
        Un vistazo a los espacios que te están esperando. Cada rincón pensado
        para hacerte sentir como en un capricho personal.
      </p>
    </div>

    <div class="grid grid-cols-12 gap-3 lg:gap-5">
      {fotos.map((foto, i) => (
        <figure class={`relative overflow-hidden group ${foto.span}`} data-reveal style={`--reveal-delay: ${i * 60}ms`}>
          <img
            src={foto.src}
            alt={foto.alt}
            loading="lazy"
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1400ms] group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-ink-950/70 via-transparent to-transparent opacity-60 group-hover:opacity-40 transition-opacity duration-500"></div>
          <figcaption class="absolute bottom-5 left-5 right-5 flex items-end justify-between gap-3">
            <span class="font-accent italic text-cream text-sm">{foto.alt}</span>
            <span class="font-numeric text-cream/60 text-xs">/ derroche</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
