---
const mapaUrl = 'https://maps.app.goo.gl/iZx4X2Zb6MWoNnLp9';
const direccion = 'Cl. 10 #62c-38, Pampa Linda, Cali, Valle del Cauca';
const mapaEmbed =
  'https://www.google.com/maps?q=' +
  encodeURIComponent(direccion) +
  '&output=embed';
---

<section id="ubicacion" class="relative py-28 lg:py-36 bg-ink-900/40 border-y border-cream/10">
  <div class="mx-auto max-w-[1500px] px-6 lg:px-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
      <div class="lg:col-span-5 lg:sticky lg:top-32" data-reveal>
        <p class="eyebrow flex items-center gap-4">
          <span class="h-px w-10 bg-crimson"></span>
          Ubicación
        </p>
        <h2 class="section-heading mt-6">
          Estamos<br />
          <span class="italic font-accent text-crimson">en Cali.</span>
        </h2>
        <p class="font-accent italic text-cream/70 text-xl mt-8 leading-relaxed">
          A un paso de tu próxima escapada. Encuéntranos fácilmente — tenemos
          parqueadero privado y acceso discreto.
        </p>

        <div class="mt-10 space-y-7">
          <div class="border-l border-crimson/60 pl-5">
            <p class="eyebrow text-cream/50">Dirección</p>
            <p class="font-display text-cream text-2xl lg:text-3xl mt-2 leading-tight">
              Cl. 10 #62c-38
            </p>
            <p class="font-accent italic text-cream/70 text-lg mt-1">
              Pampa Linda · Cali, Valle del Cauca
            </p>
            <a
              href={mapaUrl}
              target="_blank"
              rel="noopener"
              class="mt-4 inline-flex items-center gap-2 text-[11px] font-body uppercase tracking-[0.32em] text-crimson hover:text-crimson-bright transition-colors"
            >
              Abrir en Google Maps
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17l9.2-9.2M17 17V7H7"/>
              </svg>
            </a>
          </div>

          <div class="border-l border-cream/15 pl-5">
            <p class="eyebrow text-cream/50">WhatsApp</p>
            <a
              href="https://wa.me/573147241900"
              target="_blank"
              rel="noopener"
              class="font-numeric text-cream text-3xl mt-2 inline-block hover:text-crimson transition-colors"
            >
              +57 314 724 1900
            </a>
          </div>

          <div class="border-l border-cream/15 pl-5">
            <p class="eyebrow text-cream/50">Instagram</p>
            <a
              href="https://www.instagram.com/derrochecali/"
              target="_blank"
              rel="noopener"
              class="font-display text-cream text-2xl mt-2 inline-block hover:text-crimson transition-colors"
            >
              @derrochecali
            </a>
          </div>
        </div>
      </div>

      <div class="lg:col-span-7" data-reveal style="--reveal-delay: 120ms">
        <div class="relative aspect-[4/3] lg:aspect-[16/12] overflow-hidden border border-cream/10 bg-ink-900">
          <!-- Crimson accent line -->
          <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-crimson via-crimson/30 to-transparent z-20 pointer-events-none"></div>

          <iframe
            src={mapaEmbed}
            width="100%"
            height="100%"
            class="map-frame"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación Derroche Aparta Hotel"
          ></iframe>

          <!-- Tinted vignette to blend the map into the dark theme -->
          <div
            class="absolute inset-0 z-10 pointer-events-none"
            style="background: radial-gradient(120% 90% at 30% 30%, transparent 55%, rgb(var(--c-ink-950) / 0.55) 100%);"
          ></div>
          <div class="absolute inset-0 z-10 ring-1 ring-inset ring-cream/10 pointer-events-none"></div>

          <!-- Coordinates label -->
          <span class="absolute top-4 right-4 z-20 font-numeric text-cream/50 text-xs tracking-wide pointer-events-none">
            3.4206° N · 76.5460° O
          </span>

          <!-- Floating glass info card -->
          <div class="absolute bottom-5 left-5 right-5 sm:right-auto sm:max-w-sm z-20">
            <div class="relative bg-ink-950/70 backdrop-blur-md border border-cream/10 shadow-[inset_0_1px_0_rgba(245,233,215,0.08)] p-5 sm:p-6">
              <div class="flex items-start gap-4">
                <span class="mt-0.5 shrink-0 h-10 w-10 flex items-center justify-center bg-crimson text-cream">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                  </svg>
                </span>
                <div class="min-w-0">
                  <p class="font-display text-cream text-lg leading-tight">Derroche Aparta Hotel</p>
                  <p class="font-accent italic text-cream/70 text-base mt-0.5 leading-snug">
                    Cl. 10 #62c-38 · Pampa Linda
                  </p>
                  <a
                    href={mapaUrl}
                    target="_blank"
                    rel="noopener"
                    class="mt-3 inline-flex items-center gap-2 text-[11px] font-body uppercase tracking-[0.28em] text-crimson hover:text-crimson-bright transition-colors"
                  >
                    Cómo llegar
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .map-frame {
    transition: filter 0.6s ease;
  }
  /* Dark theme — invert the embed into a premium night map */
  :global(html:not(.light)) .map-frame {
    filter: invert(0.92) hue-rotate(180deg) saturate(0.72) brightness(0.95) contrast(0.95);
  }
  :global(html:not(.light)) .map-frame:hover {
    filter: invert(0.55) hue-rotate(180deg) saturate(0.85) brightness(1);
  }
  /* Light theme — keep the map natural, just slightly refined */
  :global(html.light) .map-frame {
    filter: saturate(0.92) contrast(1.02) brightness(1.01);
  }
  @media (prefers-reduced-motion: reduce) {
    .map-frame {
      transition: none;
    }
  }
</style>
