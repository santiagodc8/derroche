---
const mapaUrl = 'https://maps.app.goo.gl/iZx4X2Zb6MWoNnLp9';
const direccion = 'Cl. 10 #62c-38, Pampa Linda, Cali, Valle del Cauca';
const mapaEmbed =
  'https://www.google.com/maps?q=' +
  encodeURIComponent(direccion) +
  '&output=embed';
---

<section id="ubicacion" class="relative py-28 lg:py-36 bg-ink-900/40 border-y border-cream/10">
  <div class="mx-auto max-w-[1500px] px-6 lg:px-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
      <div class="lg:col-span-5 lg:sticky lg:top-32" data-reveal>
        <p class="eyebrow flex items-center gap-4">
          <span class="h-px w-10 bg-crimson"></span>
          Ubicación
        </p>
        <h2 class="section-heading mt-6">
          Estamos<br />
          <span class="italic font-accent text-crimson">en Cali.</span>
        </h2>
        <p class="font-accent italic text-cream/70 text-xl mt-8 leading-relaxed">
          A un paso de tu próxima escapada. Encuéntranos fácilmente — tenemos
          parqueadero privado y acceso discreto.
        </p>

        <div class="mt-10 space-y-7">
          <div class="border-l border-crimson/60 pl-5">
            <p class="eyebrow text-cream/50">Dirección</p>
            <p class="font-display text-cream text-2xl lg:text-3xl mt-2 leading-tight">
              Cl. 10 #62c-38
            </p>
            <p class="font-accent italic text-cream/70 text-lg mt-1">
              Pampa Linda · Cali, Valle del Cauca
            </p>
            <a
              href={mapaUrl}
              target="_blank"
              rel="noopener"
              class="mt-4 inline-flex items-center gap-2 text-[11px] font-body uppercase tracking-[0.32em] text-crimson hover:text-crimson-bright transition-colors"
            >
              Abrir en Google Maps
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17l9.2-9.2M17 17V7H7"/>
              </svg>
            </a>
          </div>

          <div class="border-l border-cream/15 pl-5">
            <p class="eyebrow text-cream/50">WhatsApp</p>
            <a
              href="https://wa.me/573147241900"
              target="_blank"
              rel="noopener"
              class="font-numeric text-cream text-3xl mt-2 inline-block hover:text-crimson transition-colors"
            >
              +57 314 724 1900
            </a>
          </div>

          <div class="border-l border-cream/15 pl-5">
            <p class="eyebrow text-cream/50">Instagram</p>
            <a
              href="https://www.instagram.com/derrochecali/"
              target="_blank"
              rel="noopener"
              class="font-display text-cream text-2xl mt-2 inline-block hover:text-crimson transition-colors"
            >
              @derrochecali
            </a>
          </div>
        </div>
      </div>

      <div class="lg:col-span-7" data-reveal style="--reveal-delay: 120ms">
        <div class="relative aspect-[5/4] lg:aspect-[5/6] overflow-hidden border border-cream/10">
          <iframe
            src={mapaEmbed}
            width="100%"
            height="100%"
            style="border:0; filter: grayscale(0.7) contrast(1.05) brightness(0.85);"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación Derroche Aparta Hotel"
          ></iframe>
          <!-- Overlay frame -->
          <div class="absolute inset-0 ring-1 ring-inset ring-cream/10 pointer-events-none"></div>
        </div>
      </div>
    </div>
  </div>
</section>
