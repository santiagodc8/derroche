---
const whatsapp =
  'https://wa.me/573147241900?text=' +
  encodeURIComponent('Hola Derroche, quiero aplicar el 20% de descuento. ¿Disponibilidad?');
---

<section id="promocion" class="relative py-28 lg:py-36 bg-ink-950">
  <div class="mx-auto max-w-[1500px] px-6 lg:px-12">
    <div class="relative overflow-hidden bg-gradient-to-br from-crimson-soft via-crimson to-bordeaux border border-crimson/40" data-reveal>
      <!-- Decorative arches -->
      <div class="absolute -right-32 -top-32 w-[420px] h-[420px] arch border border-ivory/15 pointer-events-none"></div>
      <div class="absolute -right-20 -top-20 w-[260px] h-[260px] arch border border-ivory/10 pointer-events-none"></div>
      <!-- Pattern -->
      <div
        class="absolute inset-0 opacity-[0.08] pointer-events-none"
        style="background-image: radial-gradient(circle at 1px 1px, rgb(var(--c-ivory)) 1px, transparent 0); background-size: 24px 24px;"
      >
      </div>

      <div class="relative grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 p-10 lg:p-20">
        <div class="lg:col-span-7">
          <p class="eyebrow text-ivory flex items-center gap-4">
            <span class="h-px w-10 bg-ivory"></span>
            Promoción vigente
          </p>

          <h2 class="font-display text-ivory leading-[0.95] mt-6">
            <span class="block text-[clamp(2.5rem,7vw,6.5rem)]">20% de</span>
            <span class="block text-[clamp(2.5rem,7vw,6.5rem)] italic font-accent text-ivory">descuento</span>
            <span class="block text-[clamp(2rem,5vw,5rem)] text-ivory/85">pagando en efectivo.</span>
          </h2>

          <p class="font-accent italic text-ivory/85 text-xl mt-8 max-w-xl leading-relaxed">
            Aplica para habitaciones Silver, Junior y Presidencial — tarifa de 3 horas.
            <span class="text-ivory">De lunes a viernes, entre 8:00 am y 5:00 pm.</span>
          </p>

          <a
            href={whatsapp}
            target="_blank"
            rel="noopener"
            class="mt-10 inline-flex items-center gap-3 bg-ivory text-bordeaux-deep px-7 py-4 text-[11px] font-body uppercase tracking-[0.32em] transition-all duration-300 hover:bg-gold-pale hover:translate-y-[-2px]"
          >
            Aplicar mi descuento
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <div class="lg:col-span-5 flex items-center justify-center">
          <div class="relative">
            <!-- Big "20%" number -->
            <div class="relative">
              <p class="font-numeric text-ivory text-[clamp(7rem,30vw,18rem)] leading-none italic">20</p>
              <span class="absolute top-2 right-[-2.5rem] font-display text-ivory text-6xl">%</span>
            </div>
            <p class="text-center font-accent italic text-ivory text-2xl mt-[-1rem]">off · efectivo</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
