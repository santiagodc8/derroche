---
const whatsapp = 'https://wa.me/573147241900?text=Hola%20Derroche%2C%20quiero%20informaci%C3%B3n%20para%20reservar.';

const links = [
  { href: '#habitaciones', label: 'Habitaciones' },
  { href: '#servicios', label: 'Servicios' },
  { href: '#promocion', label: 'Promoción' },
  { href: '#galeria', label: 'Galería' },
  { href: '#ubicacion', label: 'Ubicación' },
];
---

<header
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500"
  data-state="top"
>
  <div
    class="absolute inset-0 bg-ink-950/0 backdrop-blur-0 border-b border-cream/0 transition-all duration-500"
    data-nav-bg
  >
  </div>
  <nav class="relative mx-auto max-w-[1500px] px-6 lg:px-12 py-5 flex items-center justify-between">
    <a href="#top" class="flex items-center gap-3 group">
      <img
        src="/derroche.png"
        alt="Derroche Aparta Hotel"
        class="h-12 w-12 object-contain transition-transform duration-500 group-hover:scale-105"
      />
      <div class="hidden sm:flex flex-col leading-none">
        <span class="font-display text-cream text-xl tracking-wide">Derroche</span>
        <span class="eyebrow mt-1 text-[9px]">Aparta Hotel · Cali</span>
      </div>
    </a>

    <ul class="hidden lg:flex items-center gap-9">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class="nav-link font-body text-[11px] uppercase tracking-[0.32em] text-cream/70 transition-colors duration-300"
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-3">
      <a
        href={whatsapp}
        target="_blank"
        rel="noopener"
        class="btn-primary !py-3 !px-5 lg:!px-6 text-[10px] lg:text-[11px]"
      >
        <span class="hidden sm:inline">Reservar</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
        </svg>
      </a>

      <!-- Mobile menu toggle -->
      <button
        type="button"
        class="lg:hidden inline-flex items-center justify-center h-11 w-11 -mr-2 text-cream"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-menu-toggle
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
          <line x1="3" y1="7" x2="21" y2="7" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="17" x2="21" y2="17" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu overlay -->
  <div
    id="mobile-menu"
    class="lg:hidden fixed inset-0 z-[55] opacity-0 invisible transition-all duration-400"
    data-menu-panel
  >
    <div class="absolute inset-0 bg-ink-950/80 backdrop-blur-md" data-menu-backdrop></div>
    <nav class="absolute right-0 top-0 h-full w-[82%] max-w-sm bg-ink-900 border-l border-cream/10 translate-x-full transition-transform duration-400 ease-[cubic-bezier(0.22,1,0.36,1)] flex flex-col" data-menu-drawer>
      <div class="flex items-center justify-between px-7 py-6 border-b border-cream/10">
        <span class="font-display text-cream text-xl">Derroche</span>
        <button
          type="button"
          class="inline-flex items-center justify-center h-10 w-10 -mr-2 text-cream/70 hover:text-crimson transition-colors"
          aria-label="Cerrar menú"
          data-menu-close
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
            <line x1="6" y1="6" x2="18" y2="18" />
            <line x1="18" y1="6" x2="6" y2="18" />
          </svg>
        </button>
      </div>
      <ul class="flex flex-col px-7 py-6 gap-1">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class="block font-display text-cream text-2xl py-3 border-b border-cream/[0.06] hover:text-crimson transition-colors"
              data-menu-link
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
      <div class="mt-auto px-7 py-7 border-t border-cream/10">
        <a
          href={whatsapp}
          target="_blank"
          rel="noopener"
          class="btn-primary w-full justify-center"
          data-menu-link
        >
          Reservar por WhatsApp
        </a>
        <a
          href="https://www.instagram.com/derrochecali/"
          target="_blank"
          rel="noopener"
          class="block mt-5 eyebrow text-cream/50 hover:text-crimson transition-colors"
        >
          @derrochecali
        </a>
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  (() => {
    const nav = document.getElementById('nav');
    const bg = nav?.querySelector('[data-nav-bg]');
    if (!nav || !bg) return;
    const onScroll = () => {
      if (window.scrollY > 40) {
        bg.classList.add('!bg-ink-950/85', 'backdrop-blur-md', '!border-cream/10');
      } else {
        bg.classList.remove('!bg-ink-950/85', 'backdrop-blur-md', '!border-cream/10');
      }
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    /* Mobile menu */
    const toggle = document.querySelector('[data-menu-toggle]');
    const panel = document.querySelector('[data-menu-panel]');
    const drawer = panel?.querySelector('[data-menu-drawer]');
    const backdrop = panel?.querySelector('[data-menu-backdrop]');
    const closeBtn = panel?.querySelector('[data-menu-close]');

    const openMenu = () => {
      panel.classList.remove('opacity-0', 'invisible');
      drawer.classList.remove('translate-x-full');
      toggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    };
    const closeMenu = () => {
      panel.classList.add('opacity-0', 'invisible');
      drawer.classList.add('translate-x-full');
      toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    };

    if (toggle && panel && drawer) {
      toggle.addEventListener('click', openMenu);
      closeBtn?.addEventListener('click', closeMenu);
      backdrop?.addEventListener('click', closeMenu);
      panel.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') closeMenu();
      });
    }
  })();
</script>
